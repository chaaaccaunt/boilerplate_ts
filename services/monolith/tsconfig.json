{
  "extends": "../../tsconfig.base.json",
  "include": [
    "../../shared/**/*.d.ts",
    "../../@types",
    "../../libs/**/*.ts",
    "../../models/**/*.ts",
    "./webpack.config.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "@/libs": [
        "../../libs/index"
      ],
      "@/libs/*": [
        "../../libs/*"
      ],
      "@/models/*": [
        "../../models/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "node"
    ],
    "typeRoots": [
      "../../@types",
      "./node_modules/@types",
      "../../node_modules/@types"
    ]
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ],
    "files": true
  }
}
