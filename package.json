{
  "name": "boilerplate-ts",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/monolith",
    "monolith"
  ],
  "scripts": {
    "dev": "start npm run dev:service:monolith && start npm run dev:monolith",
    "dev:service:monolith": "npm --workspace boilerplate-ts-service-monolith run start",
    "dev:monolith": "npm --workspace boilerplate-ts-monolith run serve",
    "start:service:monolith:dist": "npm --workspace boilerplate-ts-service-monolith run start:dist",
    "install:all": "npm install",
    "install:service:monolith": "npm install --workspace boilerplate-ts-service-monolith",
    "install:monolith": "npm install --workspace boilerplate-ts-monolith",
    "typecheck:shared": "npx tsc -p shared/tsconfig.json --noEmit",
    "typecheck:service:monolith": "npm --workspace boilerplate-ts-service-monolith run typecheck",
    "typecheck:monolith": "npm --workspace boilerplate-ts-monolith run typecheck",
    "typecheck:all": "npm run typecheck:shared && npm run typecheck:service:monolith && npm run typecheck:monolith",
    "build:service:monolith": "npm --workspace boilerplate-ts-service-monolith run build",
    "build:monolith": "npm --workspace boilerplate-ts-monolith run build"
  }
}
